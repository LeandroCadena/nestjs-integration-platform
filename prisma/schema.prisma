generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  CREATED
  PAYMENT_PROCESSING
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

model Order {
  id             String      @id @default(uuid())
  customerName   String
  amount         Int
  currency       String
  status         OrderStatus @default(CREATED)
  idempotencyKey String      @unique
  correlationId  String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  payments        Payment[]
  integrationLogs IntegrationLog[]
}

model Payment {
  id                String        @id @default(uuid())
  orderId           String
  provider          String
  amount            Int
  currency          String
  status            PaymentStatus @default(PENDING)
  idempotencyKey    String        @unique
  externalPaymentId String?
  errorMessage      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

model IntegrationLog {
  id            String   @id @default(uuid())
  orderId       String?
  provider      String
  operation     String
  status        String
  requestBody   Json?
  responseBody  Json?
  errorMessage  String?
  latencyMs     Int?
  correlationId String
  createdAt     DateTime @default(now())

  order Order? @relation(fields: [orderId], references: [id])
}

model WebhookEvent {
  id              String   @id @default(uuid())
  provider        String
  eventType       String
  externalEventId String   @unique
  payload         Json
  processed       Boolean  @default(false)
  correlationId   String
  createdAt       DateTime @default(now())
}
